# Convex Configuration
# Get your Convex URL from the Convex dashboard (https://dashboard.convex.dev)
# For development: use your dev deployment URL
# For production: set this in Vercel environment variables with your prod deployment URL
PUBLIC_CONVEX_URL=https://your-deployment-name.convex.cloud

# Optional: Secret for cron job authentication
# Set this in Vercel to prevent unauthorized access to /api/sync-products
# CRON_SECRET=your-secret-key-here
